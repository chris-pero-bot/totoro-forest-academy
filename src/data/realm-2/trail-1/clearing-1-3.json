      "correctIndex": 0,
      "hint": "Brothers often look similar!",
      "acornValue": 3
    },
    {
      "id": "t9",
      "type": "fill_the_gap",
      "round": "challenge",
      "prompt": "The family has ___ people: parents, grandparents, and children.",
