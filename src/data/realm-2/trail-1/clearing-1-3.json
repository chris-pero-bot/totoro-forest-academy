      "correctIndex": 0,
      "hint": "Parents + grandparents + children = a lot!",
      "acornValue": 3
    },
    {
      "id": "t10",
      "type": "pick_one",
      "round": "challenge",
      "prompt": "Which sentence best describes a happy family?",
      "options": [
        "They love each other and spend time together.",
